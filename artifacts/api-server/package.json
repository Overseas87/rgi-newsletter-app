{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run db:migrate && pnpm run build && pnpm run start",
    "db:migrate": "pnpm --filter @workspace/db run push-force",
    "build": "node ./build.mjs",
    "build:prod": "pnpm run db:migrate && pnpm run build",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "worker": "node --enable-source-maps ./dist/worker.mjs",
    "test:professors": "tsx --test src/__tests__/professor-profiles.test.ts",
    "test:opportunities": "tsx --test src/__tests__/story-opportunities.test.ts src/__tests__/story-opportunities-api.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.17.6",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
