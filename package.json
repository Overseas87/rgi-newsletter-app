{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:local": "bash ./scripts/dev-local.sh",
    "start:local": "bash ./scripts/start-local-detached.sh",
    "stop:local": "bash ./scripts/stop-local.sh",
    "smoke:local": "bash ./scripts/smoke-local.sh",
    "smoke:firebase-readonly": "bash ./scripts/smoke-firebase-readonly.sh",
    "verify:frontend-no-admin-secret": "node ./scripts/verify-frontend-no-admin-secret.mjs",
    "test:opportunities:emulator": "firebase emulators:exec --only auth,firestore --project demo-rgi-opportunities \"bash ./scripts/test-story-opportunities-emulator-e2e.sh\""
  },
  "private": true,
  "devDependencies": {
    "firebase-tools": "15.24.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
